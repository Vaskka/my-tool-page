---
import { siteTitle } from "../config";
---

<footer class="border-t border-slate-200 mt-12 py-8 text-sm text-slate-500">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-wrap justify-between gap-4 mb-4">
      <span><span data-i18n="site.title">{siteTitle}</span> &copy; {new Date().getFullYear()}</span>
      <div class="flex gap-4">
        <a href="/privacy/" class="text-slate-500 hover:text-blue-600 no-underline" data-i18n="footer.privacy">
          Privacy Policy
        </a>
        <a href="/terms/" class="text-slate-500 hover:text-blue-600 no-underline" data-i18n="footer.terms">
          Terms of Service
        </a>
        <a href="/about/" class="text-slate-500 hover:text-blue-600 no-underline" data-i18n="nav.about">
          About
        </a>
      </div>
    </div>
  </div>
</footer>
