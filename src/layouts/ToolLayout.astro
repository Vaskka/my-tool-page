---
import BaseLayout from "./BaseLayout.astro";
import AdUnit from "../components/AdUnit.astro";

export interface Content {
  intro: string;
  steps: string[];
  tips: string[];
}

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  content: Content;
}

const { content, ...props } = Astro.props;
---

<BaseLayout
  title={props.title}
  description={props.description}
  canonical={props.canonical}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <article>
      <h1 class="text-3xl font-bold text-slate-900 mb-2">{props.title}</h1>
      <p class="text-slate-600 mb-6">{props.description}</p>

      <AdUnit slot="top" />

      <div class="my-6">
        <slot />
      </div>

      <AdUnit slot="bottom" />

      <div class="mt-8 prose prose-slate max-w-none">
        <h2>About the {props.title}</h2>
        <p>{content.intro}</p>

        <h2>How to Use</h2>
        <ol>
          {content.steps.map((step) => <li>{step}</li>)}
        </ol>

        <h2>Tips & Best Practices</h2>
        <ul>
          {content.tips.map((tip) => <li>{tip}</li>)}
        </ul>

        <div class="p-4 bg-blue-50 rounded-lg border border-blue-100 not-prose mt-6">
          <p class="text-sm text-blue-700 font-medium">
            This {props.title.toLowerCase()} runs entirely in your browser.
            No data is uploaded to any server. Your privacy is completely protected.
          </p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
