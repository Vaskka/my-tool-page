---
import BaseLayout from "./BaseLayout.astro";
import AdUnit from "../components/AdUnit.astro";

export interface Props {
  title: string;
  description: string;
  slug: string;
  canonical?: string;
}

const { slug, ...props } = Astro.props;
---

<BaseLayout
  title={props.title}
  description={props.description}
  canonical={props.canonical}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <article>
      <h1 class="text-3xl font-bold text-slate-900 mb-2" data-i18n={`tool.${slug}.title`}>{props.title}</h1>
      <p class="text-slate-600 mb-6" data-i18n={`tool.${slug}.description`}>{props.description}</p>

      <AdUnit slot="top" />

      <div class="my-6">
        <slot />
      </div>

      <AdUnit slot="bottom" />

      <div class="mt-8 prose prose-slate max-w-none">
        <h2 data-i18n={`tool.${slug}.aboutHeading`} data-i18n-tool={`tool.${slug}.title`}>About the {props.title}</h2>
        <p data-i18n={`tool.${slug}.intro`}>Loading...</p>

        <h2 data-i18n="tool.howToUseHeading">How to Use</h2>
        <ol>
          {[1, 2, 3, 4, 5].map((n) => (
            <li data-i18n={`tool.${slug}.step${n}`}>Step {n}</li>
          ))}
        </ol>

        <h2 data-i18n="tool.tipsHeading">Tips & Best Practices</h2>
        <ul>
          {[1, 2, 3, 4].map((n) => (
            <li data-i18n={`tool.${slug}.tip${n}`}>Tip {n}</li>
          ))}
        </ul>

        <div class="p-4 bg-blue-50 rounded-lg border border-blue-100 not-prose mt-6">
          <p class="text-sm text-blue-700 font-medium" data-i18n="tool.privacyNotice" data-i18n-tool={`tool.${slug}.title`}>
            This {props.title.toLowerCase()} runs entirely in your browser.
            No data is uploaded to any server. Your privacy is completely protected.
          </p>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
