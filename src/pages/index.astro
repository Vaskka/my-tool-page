---
import BaseLayout from "../layouts/BaseLayout.astro";
import { allTools, toolCategories, siteDescription } from "../config";
---

<BaseLayout title="Home" description={siteDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-slate-900 mb-3">Free Online Developer Tools</h1>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">{siteDescription}</p>
    </div>

    {toolCategories.map((category) => {
      const toolsInCategory = allTools.filter((t) => t.category === category);
      if (toolsInCategory.length === 0) return null;
      return (
        <section class="mb-10">
          <h2 class="text-2xl font-semibold text-slate-800 mb-4">{category} Tools</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {toolsInCategory.map((tool) => (
              <a href={`/tools/${tool.slug}/`} class="tool-card no-underline block">
                <h3 class="text-lg font-semibold text-blue-600 mb-1">{tool.title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{tool.description}</p>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
