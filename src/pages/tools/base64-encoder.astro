---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { Base64Encoder } from "../../components/tools/Base64Encoder";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "base64-encoder")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <Base64Encoder client:load />
</ToolLayout>