---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { CaseConverter } from "../../components/tools/CaseConverter";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "case-converter")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <CaseConverter client:load />
</ToolLayout>