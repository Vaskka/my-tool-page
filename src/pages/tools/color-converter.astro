---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { ColorConverter } from "../../components/tools/ColorConverter";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "color-converter")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <ColorConverter client:load />
</ToolLayout>