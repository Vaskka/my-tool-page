---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { HashGenerator } from "../../components/tools/HashGenerator";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "hash-generator")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <HashGenerator client:load />
</ToolLayout>