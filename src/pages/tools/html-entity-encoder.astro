---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { HtmlEntityEncoder } from "../../components/tools/HtmlEntityEncoder";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "html-entity-encoder")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <HtmlEntityEncoder client:load />
</ToolLayout>