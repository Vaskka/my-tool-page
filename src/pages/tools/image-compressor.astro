---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { ImageCompressor } from "../../components/tools/ImageCompressor";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "image-compressor")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <ImageCompressor client:load />
</ToolLayout>