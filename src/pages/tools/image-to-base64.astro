---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { ImageToBase64 } from "../../components/tools/ImageToBase64";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "image-to-base64")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <ImageToBase64 client:load />
</ToolLayout>