---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { JsonFormatter } from "../../components/tools/JsonFormatter";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "json-formatter")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <JsonFormatter client:load />
</ToolLayout>