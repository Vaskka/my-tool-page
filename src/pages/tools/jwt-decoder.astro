---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { JwtDecoder } from "../../components/tools/JwtDecoder";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "jwt-decoder")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <JwtDecoder client:load />
</ToolLayout>