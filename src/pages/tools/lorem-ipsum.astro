---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { LoremIpsum } from "../../components/tools/LoremIpsum";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "lorem-ipsum")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <LoremIpsum client:load />
</ToolLayout>