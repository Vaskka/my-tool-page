---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { MarkdownPreviewer } from "../../components/tools/MarkdownPreviewer";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "markdown-previewer")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <MarkdownPreviewer client:load />
</ToolLayout>