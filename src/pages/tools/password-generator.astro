---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { PasswordGenerator } from "../../components/tools/PasswordGenerator";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "password-generator")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <PasswordGenerator client:load />
</ToolLayout>