---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { RegexTester } from "../../components/tools/RegexTester";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "regex-tester")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <RegexTester client:load />
</ToolLayout>