---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { TextDeduplicator } from "../../components/tools/TextDeduplicator";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "text-deduplicator")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <TextDeduplicator client:load />
</ToolLayout>