---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { TextDiff } from "../../components/tools/TextDiff";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "text-diff")!;
---

<ToolLayout title={tool.title} description={tool.description} content={tool.content}>
  <TextDiff client:load />
</ToolLayout>