---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { TimestampConverter } from "../../components/tools/TimestampConverter";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "timestamp-converter")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <TimestampConverter client:load />
</ToolLayout>