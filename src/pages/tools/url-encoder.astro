---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { UrlEncoder } from "../../components/tools/UrlEncoder";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "url-encoder")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <UrlEncoder client:load />
</ToolLayout>