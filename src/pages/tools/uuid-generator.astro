---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { UuidGenerator } from "../../components/tools/UuidGenerator";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "uuid-generator")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <UuidGenerator client:load />
</ToolLayout>