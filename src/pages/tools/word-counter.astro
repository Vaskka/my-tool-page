---
import ToolLayout from "../../layouts/ToolLayout.astro";
import { WordCounter } from "../../components/tools/WordCounter";
import { allTools } from "../../config";

const tool = allTools.find((t) => t.slug === "word-counter")!;
---

<ToolLayout title={tool.title} description={tool.description} slug={tool.slug}>
  <WordCounter client:load />
</ToolLayout>